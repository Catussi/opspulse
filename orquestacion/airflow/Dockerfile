# Imagen personalizada (opcional)
#
# Por defecto usamos la imagen oficial de Apache Airflow con
# _PIP_ADDITIONAL_REQUIREMENTS en docker-compose.yml para evitar
# builds lentos y el error "pip as root" de la imagen oficial.
#
# Si prefieres imagen fija con paquetes preinstalados:
#
# FROM apache/airflow:2.10.4-python3.12
# USER airflow
# RUN pip install --no-cache-dir \
#     apache-airflow-providers-http==4.13.2 \
#     dbt-postgres==1.9.0
